# Template — render via scripts/record.sh (fills %THEME% / %SUFFIX% for the
# light and dark variants)
# Rendered at 2x (2400x1440 @ FontSize 26) for crispness; embed scaled down.
# Records inside a throwaway workspace (/tmp/vibin-demo) so no real chat
# history, paths, or usernames appear.

Output assets/demo-%SUFFIX%.gif

Set Theme "%THEME%"
Set FontSize 26
Set Width 2400
Set Height 1440
Set Padding 24
Set TypingSpeed 110ms

# launch off-camera in the demo workspace, go straight to the code shell,
# and let rust-analyzer finish indexing so diagnostics are live on camera
Hide
Type `cd /tmp/vibin-demo && vibin . -- sleep 600`
Enter
Sleep 4s
Ctrl+A
Sleep 300ms
Type "f"
Sleep 25s
Show

# open a file through the palette, typed at human speed
Sleep 1200ms
Ctrl+K
Sleep 900ms
Type "main"
Sleep 1400ms
Enter
Sleep 2s

# wander down the file like a person reading it
Type "j"
Sleep 260ms
Type "j"
Sleep 180ms
Type "j"
Sleep 320ms
Type "j"
Sleep 200ms
Type "j"
Sleep 700ms
Type "w"
Sleep 350ms
Type "w"
Sleep 280ms
Type "e"
Sleep 1600ms

# jump to the unused-variable warning; its message shows in the status bar
Type ":48"
Sleep 400ms
Enter
Sleep 900ms
Type "w"
Sleep 300ms
Type "e"
Sleep 2500ms

Screenshot assets/hero-%SUFFIX%.png

# a quick look at the git shell: staged change, diff
Ctrl+A
Sleep 350ms
Type "g"
Sleep 1800ms
Type "j"
Sleep 400ms
Enter
Sleep 2800ms
