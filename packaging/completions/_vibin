#compdef vibin
# zsh completion for vibin

_vibin() {
  local -a subcommands
  subcommands=(
    '+version:print the version and exit'
    '+update:update to the latest release'
    '+list-keybinds:print the resolved keybindings'
    '+list-actions:print every bindable action'
    '+show-config:print the resolved config as TOML'
  )

  if [[ "$words[CURRENT]" == +* ]]; then
    _describe -t commands 'vibin command' subcommands
    return
  fi

  # `vibin [dir] [-- command args...]`
  if (( CURRENT > 1 )) && [[ "$words[CURRENT-1]" == "--" ]]; then
    _command_names -e
    return
  fi
  _files -/
}

_vibin "$@"
